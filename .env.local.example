# Vercel AI Gateway. Works with AI SDK string model ids such as openai/gpt-5.4.
DATA_AGENT_PROVIDER=gateway
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5.4

# OpenAI-compatible gateways such as internal LiteLLM/AthenaAI.
# Set DATA_AGENT_PROVIDER=athenai or DATA_AGENT_PROVIDER=openai-compatible to use this path.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-5.4
OPENAI_PROVIDER_NAME=athenai
OPENAI_PROVIDER_LABEL=AthenaAI Gateway
ATHENAI_USER_AGENT=data-agent/0.0.1
